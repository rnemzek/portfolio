# === Database (Railway PostgreSQL — private networking) ===
DATABASE_URL=postgresql://user:password@host:5432/dbname

# === App Environment ===
NODE_ENV=development
PORT=3000

# === GitHub Integration ===
# Personal Access Token with read:user, repo (public) scopes
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_USERNAME=rnemzek

# === StreamZilla Showcase ===
# Origin probed for the live status badge on the root hub
STREAMING_URL=https://streaming.nemzilla.net

# === Uptime / SOC2 Engine ===
# Internal endpoint for uptime summary proxy route
UPTIME_API_URL=https://your-soc2-engine/api/uptime
UPTIME_API_KEY=your_uptime_api_key_here
